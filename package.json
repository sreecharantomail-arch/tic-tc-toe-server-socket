{
  "name": "nexaclash-ultimate",
  "version": "1.0.0",
  "description": "NexaClash Ultimate Edition - Commercial Quality Multiplayer Web Game",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,css,html,md}\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "db:seed": "node scripts/seed.js",
    "docker:build": "docker build -t nexaclash .",
    "docker:run": "docker run -p 3000:3000 --env-file .env nexaclash",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop nexaclash",
    "pm2:logs": "pm2 logs nexaclash"
  },
  "keywords": [
    "game",
    "multiplayer",
    "tic-tac-toe",
    "socket.io",
    "websocket"
  ],
  "author": "NexaClash Team",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.0",
    "socket.io": "^4.7.5",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}